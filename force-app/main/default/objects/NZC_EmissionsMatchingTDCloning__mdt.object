<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Used to select objects and fuel types to clone records for and allocation to T &amp; D losses.</description>
    <fields>
        <fullName>FieldsToClone__c</fullName>
        <description>Comma separated list of API field names to clone when creating the T&amp;D record</description>
        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>Comma separated list of API field names to clone when creating the T&amp;D record</inlineHelpText>
        <label>Fields to Clone</label>
        <length>255</length>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>FuelType__c</fullName>
        <description>Fuel type that should be converted for TD losses</description>
        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>Fuel type that should be converted for TD losses</inlineHelpText>
        <label>Fuel Type</label>
        <length>150</length>
        <required>true</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>ObjectName__c</fullName>
        <description>The Object API name this rule applies to</description>
        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>The Object API name this rule applies to</inlineHelpText>
        <label>Object Name</label>
        <length>150</length>
        <required>true</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>NZC_EmissionsMatchingTDCloning</label>
    <pluralLabel>NZC_EmissionsMatchingTDCloning</pluralLabel>
    <visibility>Public</visibility>
</CustomObject>
