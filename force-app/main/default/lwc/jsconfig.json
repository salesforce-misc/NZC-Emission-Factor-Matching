        "target": "es2017",
        "module": "es2015",
        "moduleResolution": "node",
        "lib": [
            "es2017",
            "dom"
        ],
        "experimentalDecorators": true,
        "baseUrl": ".",
        "paths": {
            "c/*": [
                "*"
