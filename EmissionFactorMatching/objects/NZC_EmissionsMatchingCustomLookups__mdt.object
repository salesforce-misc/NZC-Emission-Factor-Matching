<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Used to allow a fuel type to search a different lookup field for emissions factor base set</description>
    <fields>
        <fullName>FuelAppliesFor__c</fullName>
        <description>What fuel type does this custom lookup mapping apply for?</description>
        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>What fuel type does this custom lookup mapping apply for?</inlineHelpText>
        <label>Fuel Applies for</label>
        <length>150</length>
        <required>true</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>LookupToSearch__c</fullName>
        <description>What API lookup field name should this fuel type look into on the asset?</description>
        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>What API lookup field name should this fuel type look into on the asset?</inlineHelpText>
        <label>Lookup to Search</label>
        <length>150</length>
        <required>true</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>ObjectAppliesFor__c</fullName>
        <description>What object does this custom fuel mapping lookup apply to?</description>
        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>What object does this custom fuel mapping lookup apply to?</inlineHelpText>
        <label>Object Applies for</label>
        <length>150</length>
        <required>true</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>NZC_EmissionsMatchingCustomLookups</label>
    <pluralLabel>NZC_EmissionsMatchingCustomLookups</pluralLabel>
    <visibility>Public</visibility>
</CustomObject>
